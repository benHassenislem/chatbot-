# ── OpenAI ────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR-KEY-HERE

# Model to use (gpt-4.1-mini is fast & cheap; use gpt-4.1 for higher quality)
OPENAI_MODEL=gpt-4.1-mini

# ── Flask ─────────────────────────────────────────────────
# Secret key for session cookies — change this to a random string!
FLASK_SECRET_KEY=replace-with-a-random-secret-string

# Set to "false" in production
FLASK_DEBUG=true

# Port the server listens on
PORT=5000

# ── Chat settings ─────────────────────────────────────────
# Max messages kept in conversation history (per session)
MAX_HISTORY=50
